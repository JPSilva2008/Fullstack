ofollow" href="http://books.google.com/books?&amp;as_brr=0&amp;as_epq=Scorpions" class="external text">L</a><span typeof="mw:Entity">&nbsp;</span><span typeof="mw:Entity">•</span><span typeof="mw:Entity"> </span><a rel="mw:ExtLink nofollow" href="https://scholar.google.com/scholar?hl=pt&amp;q=Scorpions" class="external text">A</a><span typeof="mw:Entity">&nbsp;</span><span typeof="mw:Entity">•</span><span typeof="mw:Entity"> </span><a rel="mw:ExtLink nofollow" href="https://www.google.com/search?safe=off&amp;tbs=sur:fmc&amp;tbm=isch&amp;q=%22Scorpions%22+-site:wikipedia.org+-site:wikimedia.org" class="external text">I</a><span typeof="mw:Entity">&nbsp;</span><span typeof="mw:Entity">•</span><span typeof="mw:Entity"> </span><a rel="mw:ExtLink nofollow" href="https://www.google.com/custom?hl=pt&amp;cx=007734830908295939403%3Agalkqgoksq0&amp;cof=FORID%3A13%3BAH%3Aleft%3BCX%3AWikipedia%2520Reference%2520Search&amp;q=%22Scorpions%22" class="external text">WP refs</a>) <span typeof="mw:Entity">&nbsp;</span><span typeof="mw:Entity">•</span><span typeof="mw:Entity"> </span> <a rel="mw:ExtLink nofollow" href="https://wikipedialibrary.wmflabs.org/search/?q=%22Scorpions%22" class="external text"><abbr title="A Biblioteca da Wikipédia" about="#mwt4" typeof="mw:ExpandedAttrs" data-mw="{&quot;attribs&quot;:[[{&quot;txt&quot;:&quot;title&quot;},{&quot;html&quot;:&quot;<span typeof=\&quot;mw:Nowiki\&quot; id=\&quot;mwBA\&quot;>A Biblioteca da Wikipédia</span>&quot;}]]}">ABW</abbr></a> <span typeof="mw:Entity">&nbsp;</span><span typeof="mw:Entity">•</span><span typeof="mw:Entity"> </span> <a rel="mw:ExtLink nofollow" href="https://www.periodicos.capes.gov.br/index.php/acervo/buscador.html?q=all%3Acontains%28Scorpions%29&amp;mode=advanced&amp;source=all" class="external text">CAPES</a></span></span>).</span>  <span class="date-container"><i>(<span class="date">outubro de 2019</span>)</i></span></div></td></tr></tbody></table><span about="#mwt2">
